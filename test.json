          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/auth/upgrade/",
            "body": { "mode": "raw", "raw": "{\n  \"plan_type\": \"enterprise\"\n}" }
          }
        },

        {
          "name": "Change Password",
          "event": [{
            "listen": "test",
