{
  "info": {
    "name": "StreamBeat API",
    "description": "Full test collection for the StreamBeat Music Streaming API.\n\nSetup:\n1. Set {{base_url}} = http://127.0.0.1:8000\n2. Run 'Register Free User' first — access/refresh tokens are auto-saved to collection variables.\n3. Requests that require premium or admin auth have their own login steps.\n\nExecution order:\n  Auth → Billing → Music (Admin) → Playlists → Streaming → Search & Discover → Analytics",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",         "value": "http://127.0.0.1:8000" },
    { "key": "access_token",     "value": "" },
    { "key": "refresh_token",    "value": "" },
    { "key": "admin_access",     "value": "" },
    { "key": "premium_access",   "value": "" },
    { "key": "song_id",          "value": "1" },
    { "key": "artist_id",        "value": "1" },
    { "key": "album_id",         "value": "1" },
    { "key": "playlist_id",      "value": "1" }
  ],
  "item": [

    {
      "name": "1. Auth",
      "item": [

        {
          "name": "Register Free User",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "const json = pm.response.json();",
                "pm.test('Has tokens', () => pm.expect(json.tokens).to.have.property('access'));",
                "pm.collectionVariables.set('access_token',  json.tokens.access);",
                "pm.collectionVariables.set('refresh_token', json.tokens.refresh);",
                "pm.test('Role is free', () => pm.expect(json.user.role).to.eql('free'));",
                "pm.test('is_premium false', () => pm.expect(json.user.is_premium).to.be.false);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"freeuser\",\n  \"email\": \"free@streambeat.com\",\n  \"password\": \"TestPass123!\",\n  \"password2\": \"TestPass123!\"\n}"
            }
          }
        },

        {
          "name": "Register Free User — Duplicate Email (expects 400)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 400 on duplicate email', () => pm.response.to.have.status(400));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"freeuser2\",\n  \"email\": \"free@streambeat.com\",\n  \"password\": \"TestPass123!\",\n  \"password2\": \"TestPass123!\"\n}"
            }
          }
        },

        {
          "name": "Register Password Mismatch (expects 400)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 400 on mismatch', () => pm.response.to.have.status(400));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"baduser\",\n  \"email\": \"bad@streambeat.com\",\n  \"password\": \"TestPass123!\",\n  \"password2\": \"WrongPass999!\"\n}"
            }
          }
        },

        {
          "name": "Login Free User",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Has access token', () => pm.expect(json).to.have.property('access'));",
                "pm.collectionVariables.set('access_token',  json.access);",
                "pm.collectionVariables.set('refresh_token', json.refresh);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"free@streambeat.com\",\n  \"password\": \"TestPass123!\"\n}"
            }
          }
        },

        {
          "name": "Login Wrong Password (expects 401)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 401', () => pm.response.to.have.status(401));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"free@streambeat.com\",\n  \"password\": \"WrongPass!\"\n}"
            }
          }
        },

        {
          "name": "Get Profile",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Has email', () => pm.expect(json).to.have.property('email'));",
                "pm.test('Has role',  () => pm.expect(json).to.have.property('role'));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/auth/profile/"
          }
        },

        {
